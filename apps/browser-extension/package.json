{
  "name": "@mpc-wallet/browser-extension",
  "description": "MPC Wallet Browser Extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:edge": "wxt -b edge",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:unit": "bun test tests/services tests/config",
    "test:integration": "bun test tests/integration",
    "test:webrtc": "bun test tests/entrypoints/offscreen/webrtc.*.test.ts",
    "clean": "rm -rf dist .wxt",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.8",
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "@types/uuid": "^11.0.0",
    "@wxt-dev/module-svelte": "^2.0.5",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "wxt": "^0.20.26"
  },
  "dependencies": {
    "@mpc-wallet/core-wasm": "workspace:*",
    "@mpc-wallet/types": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "tailwindcss": "^4.3.0",
    "uuid": "^14.0.0",
    "viem": "^2.52.0",
    "vite-plugin-wasm": "^3.6.0"
  }
}