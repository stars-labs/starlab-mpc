import { Button, VerticalBox, HorizontalBox, LineEdit, TextEdit, ListView, StandardButton, GroupBox, GridBox, ComboBox, TabWidget, ScrollView } from "std-widgets.slint";
import { ConnectionStatus, ConnectionInfo } from "components/connection_status.slint";
import { WalletSelector, WalletInfo } from "components/wallet_selector.slint";
import { DkgProgress, Participant } from "components/dkg_progress.slint";
import { OfflineMode, SDCardOperation } from "components/offline_mode.slint";
import { SessionList, SessionInfo } from "components/session_list.slint";

export { ConnectionInfo, WalletInfo, Participant, SDCardOperation, SessionInfo }

// Enhanced global state
export global AppState {
    // Connection state
    in-out property <bool> websocket_connected: false;
    in-out property <bool> webrtc_connected: false;
    in-out property <[ConnectionInfo]> mesh_connections: [];
    in-out property <string> operation_mode: "online"; // "online", "offline", "hybrid"
    
    // Wallet state
    in-out property <[WalletInfo]> wallets: [];
    in-out property <int> active_wallet_index: 0;
    in-out property <bool> has_keystore: false;
    
    // Session state
    in-out property <[SessionInfo]> available_sessions: [];
    in-out property <SessionInfo> active_session;
    in-out property <bool> has_active_session: false;
    
    // DKG state
    in-out property <bool> dkg_active: false;
    in-out property <int> dkg_current_round: 0;
    in-out property <float> dkg_progress: 0.0;
    in-out property <[Participant]> dkg_participants: [];
    
    // Offline mode state
    in-out property <bool> offline_enabled: false;
    in-out property <bool> sd_card_detected: false;
    in-out property <[SDCardOperation]> pending_sd_operations: [];

    // Signing state. `signing_state` mirrors the Rust-side
    // SigningState enum as a lowercase string: "idle",
    // "awaiting_approval", "commitment", "share", "aggregating",
    // "complete", "failed". `signing_request_id` echoes the
    // currently-pending request so approve / reject callbacks
    // can pass it back to the core.
    in-out property <bool> has_signing_request: false;
    in-out property <string> signing_request_id: "";
    in-out property <string> signing_message_preview: "";
    in-out property <string> signing_chain: "";
    in-out property <string> signing_label: "";
    in-out property <string> signing_state: "idle";
    in-out property <string> last_signature: "";

    // UI state
    in-out property <string> device_id: "";
    in-out property <string> status_message: "Ready";
    in-out property <[string]> log_messages: [];

    // Password used to encrypt this device's key share at DKG create/join
    // time. Bound to the "Keystore password" field; read on the Rust side
    // before kicking off a real DKG.
    in-out property <string> dkg_password: "";
}

// Enhanced main window
export component MainWindow inherits Window {
    title: "MPC Wallet - Professional Edition";
    min-width: 1400px;
    min-height: 900px;
    background: #0F172A;
    
    // Callbacks
    callback connect_websocket(string);
    callback create_wallet(string);
    // import_wallet / export_wallet: second arg is the keystore
    // password. The caller reads it out of the "Keystore password"
    // LineEdit in Settings; for passwordless keystores pass "".
    callback import_wallet(string);
    callback export_wallet(string);
    callback join_session(string);
    callback create_session();
    callback leave_session();
    callback refresh_sessions();
    callback toggle_offline_mode();
    callback start_dkg();
    callback abort_dkg();

    // Offline SD-card operations. All three are parameterless —
    // the Rust side opens an rfd folder dialog to pick the SD
    // card root, then the OfflineManager reads / writes the
    // expected subdirectories (mpc_wallet_export /
    // mpc_wallet_import). The `data_type` string on export_
    // reaches CoreAdapter and is passed through as the data-type
    // label in OfflineDataPackage.
    callback export_to_sd_card(string);
    callback import_from_sd_card();
    callback clear_sd_card();

    // Signing callbacks. sign_message() kicks off a new request
    // (takes hex-encoded message + chain, e.g. "ethereum"); once
    // AppState.has_signing_request flips true the confirm modal
    // surfaces approve_signing(request_id) / reject_signing(id).
    callback sign_message(string, string);
    callback approve_signing(string);
    callback reject_signing(string);
    
    VerticalBox {
        padding: 0px;
        
        // Header
        Rectangle {
            height: 80px;
            background: @linear-gradient(90deg, #1E293B 0%, #334155 100%);
            
            HorizontalBox {
                padding: 20px;
                spacing: 24px;
                
                // Logo and title
                HorizontalBox {
                    spacing: 12px;
                    
                    Text {
                        text: "🔐";
                        font-size: 32px;
                        vertical-alignment: center;
                    }
                    
                    VerticalBox {
                        spacing: 2px;

                        Text {
                            text: "MPC Wallet";
                            color: white;
                            font-size: 24px;
                            font-weight: 700;
                        }
                        
                        Text {
                            text: "Professional Edition";
                            color: #94A3B8;
                            font-size: 12px;
                            font-weight: 500;
                        }
                    }
                }
                
                Rectangle { } // Spacer
                
                // Device ID
                HorizontalBox {
                    spacing: 8px;

                    Text {
                        text: "Device:";
                        color: #94A3B8;
                        font-size: 13px;
                    }
                    
                    Text {
                        text: AppState.device_id;
                        color: white;
                        font-size: 13px;
                        font-weight: 500;
                    }
                }
                
                // Status
                Rectangle {
                    width: 200px;
                    height: 32px;
                    border-radius: 16px;
                    background: #1E293B;
                    
                    Text {
                        text: AppState.status_message;
                        color: #10B981;
                        font-size: 12px;
                        font-weight: 500;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
        
        // Main content
        HorizontalBox {
            padding: 20px;
            spacing: 20px;
            
            // Left panel
            VerticalBox {
                width: 400px;
                spacing: 16px;
                
                // Connection status
                ConnectionStatus {
                    websocket_connected: AppState.websocket_connected;
                    webrtc_connected: AppState.webrtc_connected;
                    mesh_connections: AppState.mesh_connections;
                    offline_mode: AppState.operation_mode;
                }
                
                // Wallet selector
                WalletSelector {
                    wallets: AppState.wallets;
                    selected_index <=> AppState.active_wallet_index;
                    has_keystore: AppState.has_keystore;
                    
                    create_wallet(name) => { root.create_wallet(name); }
                    // WalletSelector's own inline Import/Export
                    // buttons fire with an empty password — use
                    // them for unencrypted / dev keystores. For
                    // encrypted keystores use the dedicated
                    // password-aware Import/Export in Settings.
                    import_wallet => { root.import_wallet(""); }
                    export_wallet => { root.export_wallet(""); }
                }
                
                // Offline mode
                OfflineMode {
                    offline_enabled <=> AppState.offline_enabled;
                    sd_card_detected: AppState.sd_card_detected;
                    pending_operations: AppState.pending_sd_operations;
                    
                    toggle_offline_mode => { root.toggle_offline_mode(); }
                    export_to_sd_card(data_type) => {
                        root.export_to_sd_card(data_type);
                    }
                    import_from_sd_card => { root.import_from_sd_card(); }
                    clear_sd_card => { root.clear_sd_card(); }
                }
                
                // Session list
                SessionList {
                    available_sessions: AppState.available_sessions;
                    active_session: AppState.active_session;
                    has_active_session: AppState.has_active_session;
                    
                    join_session(id) => { root.join_session(id); }
                    create_session => { root.create_session(); }
                    leave_session => { root.leave_session(); }
                    refresh_sessions => { root.refresh_sessions(); }
                }
            }
            
            // Right panel
            VerticalBox {
                spacing: 16px;
                
                // DKG Progress
                DkgProgress {
                    active: AppState.dkg_active;
                    current_round: AppState.dkg_current_round;
                    progress: AppState.dkg_progress;
                    participants: AppState.dkg_participants;
                    session_id: AppState.active_session.session_id;
                    threshold: AppState.active_session.threshold;
                    
                    abort_dkg => { root.abort_dkg(); }
                }
                
                // Tab content
                TabWidget {
                    Tab {
                        title: "Operations";
                        
                        VerticalBox {
                            padding: 20px;
                            spacing: 16px;
                            
                            GroupBox {
                                title: "DKG Operations";
                                
                                VerticalBox {
                                    spacing: 12px;
                                    
                                    Button {
                                        text: "Start DKG";
                                        enabled: AppState.has_active_session && !AppState.dkg_active;
                                        clicked => { root.start_dkg(); }
                                    }
                                }
                            }
                            
                            GroupBox {
                                title: "Signing Operations";
                                
                                VerticalBox {
                                    spacing: 12px;
                                    
                                    Text {
                                        text: "Signing features coming soon...";
                                        color: #64748B;
                                        font-size: 13px;
                                    }
                                }
                            }
                        }
                    }
                    
                    Tab {
                        title: "Logs";

                        // Slint 1.x doesn't expose String.join on [string]
                        // and TextEdit has no font-family property. Render
                        // each log line as a Text inside a scrollable
                        // VerticalBox instead.
                        ScrollView {
                            VerticalBox {
                                padding: 4px;
                                spacing: 0px;
                                for line in AppState.log_messages: Text {
                                    text: line;
                                    font-size: 11px;
                                    color: #CBD5E1;
                                }
                            }
                        }
                    }
                    
                    Tab {
                        title: "Settings";

                        VerticalBox {
                            padding: 20px;
                            spacing: 16px;

                            GroupBox {
                                title: "Network Settings";

                                GridBox {
                                    Row {
                                        Text {
                                            text: "WebSocket Server:";
                                            vertical-alignment: center;
                                        }

                                        LineEdit {
                                            text: "wss://xiongchenyu.dpdns.org";
                                            placeholder-text: "Enter WebSocket URL";
                                        }

                                        Button {
                                            text: "Connect";
                                            clicked => { root.connect_websocket("wss://xiongchenyu.dpdns.org"); }
                                        }
                                    }
                                }
                            }

                            // Keystore password + password-aware
                            // Import / Export buttons. The inline
                            // WalletSelector buttons fire with "";
                            // these pass the contents of the
                            // password field to rfd-backed file
                            // dialogs handled in core_adapter.rs.
                            GroupBox {
                                title: "Keystore (encrypted import/export)";

                                VerticalBox {
                                    spacing: 8px;

                                    keystore-pw := LineEdit {
                                        placeholder-text: "Keystore password";
                                        input-type: password;
                                        text <=> AppState.dkg-password;
                                    }

                                    HorizontalBox {
                                        Button {
                                            text: "Import with password…";
                                            clicked => {
                                                root.import_wallet(keystore-pw.text);
                                            }
                                        }
                                        Button {
                                            text: "Export with password…";
                                            enabled: AppState.has_keystore;
                                            clicked => {
                                                root.export_wallet(keystore-pw.text);
                                            }
                                        }
                                    }
                                }
                            }

                            // Sign Message panel — lets the user
                            // enter a hex-encoded payload and chain
                            // label, then fires sign_message() which
                            // opens the confirm modal below.
                            GroupBox {
                                title: "Sign Message (MPC)";

                                VerticalBox {
                                    spacing: 8px;

                                    sign-hex := LineEdit {
                                        placeholder-text: "Message hex (0x… or raw hex)";
                                    }
                                    sign-chain := LineEdit {
                                        placeholder-text: "Chain (ethereum / solana / …)";
                                        text: "ethereum";
                                    }

                                    HorizontalBox {
                                        Button {
                                            text: "Request Signing";
                                            enabled: AppState.has_keystore
                                                     && AppState.signing_state == "idle";
                                            clicked => {
                                                root.sign_message(sign-hex.text, sign-chain.text);
                                            }
                                        }

                                        Rectangle {}

                                        if AppState.last_signature != "": Text {
                                            text: "Last signature: " + AppState.last_signature;
                                            color: #94A3B8;
                                            font-size: 11px;
                                            overflow: elide;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // Signing confirmation modal — rendered above the tab content
    // when AppState.has_signing_request flips true (core sets this
    // via UICallback::update_signing_request once
    // SigningState == AwaitingApproval).
    if AppState.has_signing_request: Rectangle {
        background: #000000CC;
        // Fill the entire window.
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 520px;
            height: 360px;
            border-radius: 12px;
            background: #1E293B;
            border-width: 1px;
            border-color: #334155;

            VerticalBox {
                padding: 24px;
                spacing: 16px;

                Text {
                    text: "Confirm signing request";
                    color: white;
                    font-size: 18px;
                    font-weight: 700;
                }

                if AppState.signing_label != "": Text {
                    text: AppState.signing_label;
                    color: #E2E8F0;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                Rectangle {
                    border-radius: 6px;
                    background: #0F172A;
                    VerticalBox {
                        padding: 12px;
                        spacing: 4px;
                        Text {
                            text: "Chain: " + AppState.signing_chain;
                            color: #94A3B8;
                            font-size: 12px;
                        }
                        Text {
                            text: "Message:";
                            color: #94A3B8;
                            font-size: 12px;
                        }
                        Text {
                            text: AppState.signing_message_preview;
                            color: white;
                            font-size: 11px;
                            wrap: word-wrap;
                            overflow: elide;
                        }
                    }
                }

                Text {
                    text: "Phase: " + AppState.signing_state;
                    color: #64748B;
                    font-size: 11px;
                }

                Rectangle {}

                HorizontalBox {
                    spacing: 12px;

                    Button {
                        text: "Reject";
                        clicked => {
                            root.reject_signing(AppState.signing_request_id);
                        }
                    }

                    Rectangle {}

                    Button {
                        text: AppState.signing_state == "awaiting_approval"
                              ? "Approve & Sign"
                              : "Signing…";
                        primary: true;
                        enabled: AppState.signing_state == "awaiting_approval";
                        clicked => {
                            root.approve_signing(AppState.signing_request_id);
                        }
                    }
                }
            }
        }
    }
}