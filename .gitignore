test-results/
*.test.js.map
# Offline DKG audit-tooling runs. Each invocation emits a dated dir
# under `apps/tui/` containing mock-SD-card contents, test key
# packages, and an auto-generated report. These are run-local dev
# artefacts, not third-party audits — keep them out of git so nobody
# mistakes them for production audit evidence.
apps/tui/audit_offline_dkg_*/

# Temporary files
*.tmp
*.temp
.cache/

# Claude Code session runtime state (lockfiles, caches). Team
# settings at .claude/settings.json are still tracked; only the
# transient per-session artefacts are ignored.
.claude/scheduled_tasks.lock
.claude/*.log
.claude/worktrees/

# Extension build artifacts
public/index.js
public/index_bg.wasm
public/index.d.ts

# Lock files conflict backups
*.sync-conflict-*

# Usage tracking
usage_tracking*.json
uploads/
# Python bytecode (demo scripts)
__pycache__/
*.pyc

# Cloudflare wrangler local state
.wrangler/
